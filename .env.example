# CloudHosting AI Panel — runtime env. The real .env is gitignored.

# Which product this panel instance manages (selects adapters/<product>.js):
#   openclaw | hermes | flowise | langflow | dify
PRODUCT=hermes

# Port the panel listens on inside the container (Caddy fronts it on :8443).
PANEL_PORT=8080

# Public hostname; used for builder "Open product" links.
# vps-<3rd octet>-<4th octet>.cloudhosting.lv (derived from the VM IP).
PANEL_DOMAIN=

# Turnkey avots: the provisioner sets this per client; on startup the panel
# auto-connects avots as the primary (idempotent). Leave blank to require the
# client to pick a provider in the UI.
AVOTS_API_KEY=

# hermes adapter: the shared data dir the agent reads (config.yaml + .env).
# In the hermes-vm compose the panel mounts ./data at /data, so set this to /data.
HERMES_DATA_DIR=/data

# openclaw adapter (NATIVE host deploy only): path to the openclaw CLI.
OPENCLAW_BIN=/usr/bin/openclaw
