# CloudHosting AI Panel — environment template. Copy to .env and fill in.
# The real .env is gitignored and injected per VM at provision time.
# NEVER commit a real .env.

# Which product this VM runs. Drives the whole panel behavior.
#   agents  (panel writes config): hermes | openclaw
#   builders(panel only links UI): flowise | langflow | dify
PRODUCT=

# Single panel password (fail-closed: the app refuses to start if this is empty).
# Use a strong unique value per VM.
PANEL_PASSWORD=REPLACE_ME

# Internal HTTP port the panel listens on. Caddy in front terminates TLS and
# reverse-proxies to this. Plain HTTP here is intentional.
PANEL_PORT=8080

# Public domain the product UI is served on (used for the builder "Open <product>"
# button and can front the panel under /setup). e.g. ai.client.example
PANEL_DOMAIN=

# Optional: where the shared product data dir is mounted inside the panel
# container. Defaults to /data. The panel writes the agent config + .env here,
# then touches /data/.apply-request to signal the host applier.
# PANEL_DATA_DIR=/data

# Optional: stable session-cookie signing secret. If unset a random one is
# generated per process (restart = users logged out, which is fine for a wizard).
# PANEL_SESSION_SECRET=
